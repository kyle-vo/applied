{
  "manifest_version": 3,
  "name": "Applied — Job Tracker",
  "version": "1.0.0",
  "description": "Add job postings to Applied with one click",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://backend-production-ab8c.up.railway.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Add to Applied"
  },
  "options_page": "settings.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://indeed.com/*",
        "https://www.indeed.com/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://jobs.ashbyhq.com/*",
        "https://*.jobvite.com/*",
        "https://jobs.smartrecruiters.com/*",
        "https://simplify.jobs/*",
        "https://*.joinhandshake.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
